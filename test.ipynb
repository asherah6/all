    "data = []\n",
    " \n",
    "smallest = 0\n",
    "\n",
    "import random\n",
    " \n",
    "for i in range(10):\n",
    "    num = random.randint(-10, 10)\n",
    "    data.append(num)\n",
    " \n",
    "for j in data:\n",
    "    if j < smallest:\n",
    "        smallest = j\n",
    " \n",
    " \n",
    "print(data)\n",
    "print(smallest)\n",
    "\n"
   ]
  }
