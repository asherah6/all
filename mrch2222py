# BIMARY SEARCH ALGRTM:

lst = [8,10,11,16,20,25]
num = 25
 
def binary_search(lst, num):
    left = 0
    right = len(lst)-1
    while left <= right:
        mid = (left + right)//2
        if lst[mid] == num:
            return mid
        elif lst[mid] < num:
            left = mid + 1
        else:
            right = mid -1
    return -1

print(binary_search(lst, num))

